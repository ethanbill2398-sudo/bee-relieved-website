{
  "buildCommand": "npx tinacms build --skip-cloud-checks",
  "outputDirectory": ".",
  "framework": null,
  "rewrites": [
    { "source": "/admin", "destination": "/public/admin/index.html" },
    { "source": "/admin/(.*)", "destination": "/public/admin/$1" },
    { "source": "/((?!admin).*)", "destination": "/index.html" }
  ]
}
