{
  "buildCommand": "npx tinacms build",
  "outputDirectory": ".",
  "framework": null,
  "rewrites": [
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/(.*)", "destination": "/admin/$1" },
    { "source": "/((?!admin).*)", "destination": "/index.html" }
  ]
}
